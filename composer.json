{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "cloudinary-labs/cloudinary-laravel": "^3.0",
        "filament/filament": "^3.2",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "ElnusaPuspitaPratama/app/",
            "Database\\Factories\\": "ElnusaPuspitaPratama/database/factories/",
            "Database\\Seeders\\": "ElnusaPuspitaPratama/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "ElnusaPuspitaPratama/tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
